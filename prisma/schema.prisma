generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth.js tables ───────────────────────────────────────────────────────────

model User {
  id            String    @id @default(cuid())
  name          String?
  email         String    @unique
  emailVerified DateTime?
  image         String?
  role          String    @default("admin") // super_admin | admin | viewer
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts            Account[]
  sessions            Session[]
  batches             Batch[]
  reviewedSuggestions PromptSuggestion[] @relation("ReviewedBy")
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Business tables ──────────────────────────────────────────────────────────

model Agent {
  id            String   @id @default(uuid())
  retellAgentId String   @unique
  name          String
  prompt        String?  @db.Text
  promptDraft   String?  @db.Text
  voice         String?
  language      String   @default("en")
  isActive      Boolean  @default(true)
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  calls             Call[]
  contacts          Contact[]
  promptSuggestions PromptSuggestion[]
}

model Batch {
  id            String    @id @default(uuid())
  userId        String
  name          String
  totalContacts Int       @default(0)
  status        String    @default("draft") // draft | running | completed | paused
  startedAt     DateTime?
  completedAt   DateTime?
  createdAt     DateTime  @default(now())

  user              User               @relation(fields: [userId], references: [id])
  contacts          Contact[]
  promptSuggestions PromptSuggestion[]
}

model Contact {
  id              String   @id @default(uuid())
  batchId         String?
  assignedAgentId String?
  firstName       String?
  lastName        String?
  phone           String
  address         String?
  status          String   @default("pending") // pending | called | converted | rejected | dnc | no_answer
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  batch         Batch?  @relation(fields: [batchId], references: [id])
  assignedAgent Agent?  @relation(fields: [assignedAgentId], references: [id])
  calls         Call[]
}

model Call {
  id               String    @id @default(uuid())
  agentId          String
  contactId        String?
  retellCallId     String?   @unique
  customerName     String?
  customerPhone    String
  customerAddress  String?
  startedAt        DateTime?
  endedAt          DateTime?
  durationSeconds  Int?
  result           String?   // positive | rejected | dnc | no_answer
  processingStatus String    @default("unprocessed") // unprocessed | processed
  summary          String?   @db.Text
  transcript       String?   @db.Text
  audioUrl         String?
  cost             Decimal?  @db.Decimal(10, 4)
  createdAt        DateTime  @default(now())

  agent    Agent    @relation(fields: [agentId], references: [id])
  contact  Contact? @relation(fields: [contactId], references: [id])
  dncEntry DncList?
}

model DncList {
  id           String   @id @default(uuid())
  sourceCallId String?  @unique
  phone        String   @unique
  reason       String?
  addedAt      DateTime @default(now())

  sourceCall Call? @relation(fields: [sourceCallId], references: [id])
}

model PromptSuggestion {
  id             String    @id @default(uuid())
  agentId        String
  batchId        String
  reviewedBy     String?
  suggestionText String    @db.Text
  status         String    @default("pending") // pending | accepted | rejected | implemented
  reviewedAt     DateTime?
  createdAt      DateTime  @default(now())

  agent    Agent  @relation(fields: [agentId], references: [id])
  batch    Batch  @relation(fields: [batchId], references: [id])
  reviewer User?  @relation("ReviewedBy", fields: [reviewedBy], references: [id])
}
